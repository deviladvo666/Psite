{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["src/components/*"],
      "@/modules/*": ["src/modules/*"],
      "@/lib/*": ["src/lib/*"],
      "@/i18n/*": ["src/i18n/*"],
      "@/server/*": ["src/server/*"]
    },
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ]
  },
  "include": ["src", "sanity", "tests", "messages", "next-env.d.ts"],
  "exclude": ["node_modules"]
}
